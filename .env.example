DOCQA_ENVIRONMENT=local
DOCQA_LOG_LEVEL=INFO
DOCQA_ALLOWED_ORIGINS=["http://localhost:8501","http://localhost:5173","http://127.0.0.1:5173"]
DOCQA_MAX_UPLOAD_MB=20
DOCQA_API_BASE_URL=http://localhost:8000
DOCQA_LLM_PROVIDER=openai
DOCQA_OPENAI_MODEL=gpt-4.1-mini
DOCQA_OPENAI_MAX_OUTPUT_TOKENS=800
DOCQA_OPENAI_TIMEOUT_SECONDS=20
DOCQA_OPENAI_MAX_RETRIES=1
DOCQA_OPENAI_STORE=false

# OpenAI SDK 표준 환경변수입니다. 실제 값은 .env 또는 배포 Secret에만 둡니다.
OPENAI_API_KEY=

# Render/FastAPI only. Never expose these values to the frontend.
DATABASE_URL=
DOCQA_SUPABASE_URL=
DOCQA_SUPABASE_PUBLISHABLE_KEY=
DOCQA_SUPABASE_JWT_SECRET=

# Vercel/React only. These are public client settings.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
